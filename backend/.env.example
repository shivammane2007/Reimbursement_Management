# Backend Environment Variables
# Copy this to .env and fill in your values

# Database connection string
# SQLite for local: "file:./dev.db"
# PostgreSQL for production: "postgresql://user:password@localhost:5432/dbname?schema=public"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/reimbursement?schema=public"

# Auth
JWT_SECRET="changeme-min-32-characters-long-secret"
JWT_EXPIRE="7d"
PORT=5000
FRONTEND_URL="http://localhost:3000"
NODE_ENV="development"
