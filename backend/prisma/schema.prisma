// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
//  ENUMS (SQLite workaround via String fields)
// ─────────────────────────────────────────────

// User Roles: EMPLOYEE | MANAGER | ADMIN
// ExpenseStatus: DRAFT | WAITING_APPROVAL | APPROVED | REJECTED
// ApprovalAction: APPROVED | REJECTED | FORWARDED

// ─────────────────────────────────────────────
//  MODELS
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("EMPLOYEE") // EMPLOYEE | MANAGER | ADMIN
  currency  String   @default("USD")
  country   String   @default("US")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Self-referential: who is this user's manager?
  managerId String?
  manager   User?    @relation("UserManager", fields: [managerId], references: [id])
  reports   User[]   @relation("UserManager")

  // Expenses submitted by this user
  expenses  Expense[]

  // Approval actions taken by this user
  approvalLogs ApprovalLog[]

  @@map("users")
}

model Expense {
  id              String   @id @default(cuid())
  description     String
  amount          Float
  currency        String
  convertedAmount Float    // In company base currency (USD)
  category        String
  date            DateTime
  receiptUrl      String?  // Optional: path to uploaded receipt file
  ocrRawText      String?  // Store OCR extracted text for auditing
  status          String   @default("DRAFT") // DRAFT | WAITING_APPROVAL | APPROVED | REJECTED
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Submitter
  employeeId String
  employee   User   @relation(fields: [employeeId], references: [id])

  // Which rule was applied
  ruleId String?
  rule   ApprovalRule? @relation(fields: [ruleId], references: [id])

  // Approval history
  approvalLogs ApprovalLog[]

  @@map("expenses")
}

model ApprovalLog {
  id        String   @id @default(cuid())
  action    String   // APPROVED | REJECTED | FORWARDED
  comment   String
  step      Int      // Which step in the chain (1, 2, 3...)
  createdAt DateTime @default(now())

  expenseId String
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  approverId String
  approver   User   @relation(fields: [approverId], references: [id])

  @@map("approval_logs")
}

model ApprovalRule {
  id                    String   @id @default(cuid())
  name                  String   @unique
  description           String?
  isActive              Boolean  @default(true)
  minApprovalPercentage Float    @default(100) // % of approvers that must approve
  includeDirectManager  Boolean  @default(false) // Auto-add direct manager at step 1
  overrideApproverId    String?  // If this user approves, immediately approved
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Ordered approval steps
  steps    ApprovalStep[]
  expenses Expense[]

  @@map("approval_rules")
}

model ApprovalStep {
  id       String @id @default(cuid())
  order    Int    // Step sequence (1, 2, 3...)
  userId   String // The approver for this step

  ruleId String
  rule   ApprovalRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([ruleId, order])
  @@map("approval_steps")
}
